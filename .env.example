# Stash Configuration
# Copy this file to .env and fill in your values

# PostgreSQL connection string (required)
# Format: postgres://user:password@host:port/database?sslmode=disable
#
# For local development (outside Docker):
# STASH_POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/stash?sslmode=disable
#
# For Docker Compose (use this with docker-compose.yml):
STASH_POSTGRES_DSN=postgres://stash:stash_dev_password@postgres:5432/stash?sslmode=disable

# Vector dimension - must match your embedding model (required)
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
STASH_VECTOR_DIM=1536

# Maximum results per query (required)
STASH_MAX_RESULT_SIZE=10000

# OpenAI API configuration (required)
# Use OpenAI, OpenRouter, or any OpenAI-compatible endpoint
STASH_OPENAI_API_KEY=your-openai-api-key-here
STASH_OPENAI_BASE_URL=https://api.openai.com/v1

# Atlas Cloud example:
# STASH_OPENAI_API_KEY=your-atlas-cloud-api-key
# STASH_OPENAI_BASE_URL=https://api.atlascloud.ai/v1
# STASH_EMBEDDING_MODEL=text-embedding-3-small
# STASH_REASONER_MODEL=deepseek-ai/DeepSeek-V3-0324
# STASH_VECTOR_DIM=1536

# Embedding model (required)
# OpenAI: text-embedding-3-small, text-embedding-3-large
# OpenRouter: openai/text-embedding-3-small
STASH_EMBEDDING_MODEL=text-embedding-3-small

# Reasoning model for relationship extraction (required)
# OpenAI: gpt-4o-mini, gpt-4o
# OpenRouter: openai/gpt-4o-mini, google/gemma-4-26b-a4b-it
STASH_REASONER_MODEL=gpt-4o-mini

# --- Ollama (fully local — see docs/LOCAL_OLLAMA.md) ---
# STASH_OPENAI_API_KEY=ollama
# STASH_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# STASH_EMBEDDING_MODEL=nomic-embed-text
# STASH_REASONER_MODEL=qwen2.5:3b
# STASH_VECTOR_DIM=768

# Memory Configuration
# Time-to-live for context (working memory windows)
# Format: 1h, 30m, 2h30m, etc.
STASH_CONTEXT_TTL=1h

# Server Configuration
# HTTP address to listen on
STASH_HTTP_ADDR=:8080

# Log level: debug, info, warn, error
STASH_LOG_LEVEL=info

# Log format: text or json
STASH_LOG_FORMAT=text

# Consolidation Configuration
# Number of events to process per consolidation run
STASH_CONSOLIDATION_BATCH_SIZE=100

# Similarity threshold for clustering events (0.0 to 1.0)
STASH_CONSOLIDATION_SIMILARITY_THRESHOLD=0.85

# Similarity threshold for detecting duplicate facts (0.0 to 1.0)
# Facts with similarity above this threshold are skipped as duplicates
STASH_CONSOLIDATION_DEDUP_THRESHOLD=0.85

# Time window for event consolidation (e.g., 168h = 7 days)
STASH_CONSOLIDATION_WINDOW=168h

# Optional: Specify custom config file location
# STASHCONFIG=/path/to/your/.env
