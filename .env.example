# Stash Configuration Example
# Copy this file to .env and fill in your values

# Store Configuration
# Only PostgreSQL is supported
STASH_STORE_DRIVER=postgres

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
STASH_STORE_DSN=postgres://postgres:postgres@localhost:5432/stash?sslmode=disable

# Vector dimension - must match your embedder model
# OpenAI text-embedding-3-small: 1536
# OpenAI text-embedding-3-large: 3072
# Other models: check documentation
STASH_VECTOR_DIM=1536

# Maximum number of results returned by search/list operations
STASH_MAX_RESULT_SIZE=10000

# Embedder Configuration
# Only OpenAI-compatible APIs are supported
STASH_EMBEDDER_DRIVER=openai

# OpenAI API key
STASH_OPENAI_API_KEY=your-openai-api-key-here

# OpenAI-compatible API base URL
# OpenAI: https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
# Local Ollama: http://localhost:11434/v1
STASH_OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding model name
# OpenAI: text-embedding-3-small, text-embedding-3-large
# OpenRouter: openai/text-embedding-3-small
# Ollama: nomic-embed-text
STASH_EMBEDDING_MODEL=text-embedding-3-small

# Reasoner Configuration (required for relationship extraction)
# Only OpenAI-compatible APIs are supported
STASH_REASONER_DRIVER=openai

# Reasoning model name
# Google Gemma via OpenRouter: google/gemma-4-26b-a4b-it
# OpenAI: gpt-4o-mini, gpt-4o
# OpenRouter: openai/gpt-4o-mini
STASH_REASONER_MODEL=google/gemma-4-26b-a4b-it

# Memory Configuration
# Time-to-live for context (working memory windows)
# Format: 1h, 30m, 2h30m, etc.
STASH_CONTEXT_TTL=1h

# Server Configuration
# HTTP address to listen on
STASH_HTTP_ADDR=:8080

# Log level: debug, info, warn, error
STASH_LOG_LEVEL=info

# Log format: text or json
STASH_LOG_FORMAT=text

# Optional: Specify custom config file location
# STASHCONFIG=/path/to/your/.env